<Page
    x:Class="Tossakan.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Tossakan.Models">

    <Grid x:Name="RootGrid">
        <ScrollViewer>
            <StackPanel MaxWidth="960" Padding="32,24" Spacing="16" HorizontalAlignment="Stretch">
                <Border Background="{ThemeResource ListSurfaceBrush}" CornerRadius="10" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Your boards" Style="{ThemeResource SubtitleTextBlockStyle}" />

                        <GridView x:Name="BoardsView" IsItemClickEnabled="True" SelectionMode="None"
                                  ItemClick="BoardsView_ItemClick">
                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="models:Board">
                                    <Grid Width="220" Height="110" CornerRadius="8"
                                          Background="{x:Bind Converter={StaticResource BoardBackground}}"
                                          Padding="14,10">
                                        <Grid.ContextFlyout>
                                            <MenuFlyout>
                                                <MenuFlyoutItem Text="Rename / background" Click="EditBoard_Click" Tag="{x:Bind}">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE70F;" /></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem Text="Archive" Click="ArchiveBoard_Click" Tag="{x:Bind}">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE7B8;" /></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutSeparator />
                                                <MenuFlyoutItem Text="Delete" Click="DeleteBoard_Click" Tag="{x:Bind}">
                                                    <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" /></MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                            </MenuFlyout>
                                        </Grid.ContextFlyout>
                                        <TextBlock Text="{x:Bind Name}" Foreground="White" FontWeight="SemiBold"
                                                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="3" />
                                    </Grid>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>

                        <Button Click="CreateBoard_Click" HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="14" />
                                <TextBlock Text="Create new board" />
                            </StackPanel>
                        </Button>

                        <Expander x:Name="ArchivedExpander" Header="Archived boards" HorizontalAlignment="Stretch"
                                  Margin="0,16,0,0" Visibility="Collapsed">
                            <ItemsControl x:Name="ArchivedBoardsView">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:Board">
                                        <Grid Padding="4,6" ColumnSpacing="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Width="28" Height="20" CornerRadius="3"
                                                    Background="{x:Bind BackgroundColor, Converter={StaticResource ColorToBrush}}" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind Name}" VerticalAlignment="Center" />
                                            <Button Grid.Column="2" Content="Restore" Click="RestoreBoard_Click" Tag="{x:Bind}" />
                                            <Button Grid.Column="3" Content="Delete" Click="DeleteBoard_Click" Tag="{x:Bind}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
