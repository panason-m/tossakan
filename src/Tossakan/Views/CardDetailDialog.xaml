<ContentDialog
    x:Class="Tossakan.Views.CardDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Tossakan.ViewModels"
    CloseButtonText="Close"
    Closing="Dialog_Closing">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">760</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">840</x:Double>
    </ContentDialog.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="640">
        <StackPanel Spacing="18" Width="640" Padding="0,0,12,8">

            <!-- Title + location -->
            <StackPanel Spacing="4">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock x:Name="ReferenceCodeText" Margin="10,0,0,0" FontSize="12"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <Button Background="Transparent" BorderThickness="0" Padding="4"
                            Click="CopyReference_Click" ToolTipService.ToolTip="Copy reference">
                        <FontIcon Glyph="&#xE8C8;" FontSize="10" />
                    </Button>
                </StackPanel>
                <TextBox x:Name="TitleBox" FontSize="18" FontWeight="SemiBold"
                         BorderThickness="0" Background="Transparent" TextWrapping="Wrap" />
                <TextBlock x:Name="ListLocationText" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="10,0,0,0" FontSize="12" />
            </StackPanel>

            <!-- Labels -->
            <StackPanel Spacing="8">
                <TextBlock Text="Labels" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <ItemsControl ItemsSource="{x:Bind LabelChips}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:LabelChipVm">
                            <Grid Background="{x:Bind Brush, Mode=OneWay}" CornerRadius="4"
                                  MinWidth="56" MinHeight="30" RightTapped="LabelChip_RightTapped" Tag="{x:Bind}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                                        Padding="10,4" HorizontalContentAlignment="Left"
                                        Click="LabelChip_Click" Tag="{x:Bind}"
                                        ToolTipService.ToolTip="Toggle this label on the card">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <TextBlock Text="{x:Bind Name, Mode=OneWay}" FontSize="12" Foreground="White" />
                                        <FontIcon Glyph="&#xE73E;" FontSize="11" Foreground="White"
                                                  Visibility="{x:Bind IsChecked, Mode=OneWay}" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="1" Background="Transparent" BorderThickness="0"
                                        Padding="6,4" Click="LabelChip_Edit_Click" Tag="{x:Bind}"
                                        ToolTipService.ToolTip="Rename, recolor or delete this label">
                                    <FontIcon Glyph="&#xE70F;" FontSize="10" Foreground="White" />
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <Button Content="New label" Click="NewLabel_Click" FontSize="12" />
            </StackPanel>

            <!-- Due date + cover -->
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Spacing="8">
                    <TextBlock Text="Due date" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <CalendarDatePicker x:Name="DuePicker" PlaceholderText="Set due date" Width="180"
                                            DateChanged="DuePicker_DateChanged" />
                        <CheckBox x:Name="DueCompleteBox" Content="Complete" MinWidth="0"
                                  Checked="DueComplete_Changed" Unchecked="DueComplete_Changed" />
                        <Button x:Name="ClearDueButton" Content="Remove" Click="ClearDue_Click" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Spacing="8">
                    <TextBlock Text="Cover" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <GridView x:Name="CoverPalette" Grid.Column="0" HorizontalAlignment="Left"
                                  SelectionMode="Single" SelectionChanged="Cover_SelectionChanged"
                                  ScrollViewer.HorizontalScrollMode="Disabled" MaxWidth="330">
                            <GridView.ItemTemplate>
                                <DataTemplate x:DataType="x:String">
                                    <Border Width="36" Height="24" CornerRadius="4"
                                            Background="{Binding Converter={StaticResource ColorToBrush}}" />
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                        <Button Grid.Column="1" Content="None" VerticalAlignment="Top" Click="ClearCover_Click" />
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Description -->
            <StackPanel Spacing="8">
                <TextBlock Text="Description" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <Border x:Name="DescriptionViewBorder" Background="{ThemeResource CardSurfaceBrush}"
                        CornerRadius="4" Padding="10,8"
                        ToolTipService.ToolTip="Double-click to edit. Supports # headers, - bullets, 1. numbered lists, **bold** and *italic*." />
                <StackPanel x:Name="DescriptionEditPanel" Spacing="6" Visibility="Collapsed">
                    <TextBox x:Name="DescriptionBox" AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="96" MaxHeight="220" PlaceholderText="Add a more detailed description…"
                             ScrollViewer.VerticalScrollBarVisibility="Auto" Paste="DescriptionBox_Paste"
                             LostFocus="DescriptionBox_LostFocus" />
                    <Button Content="Save" Click="SaveDescription_Click" HorizontalAlignment="Left"
                            Style="{ThemeResource AccentButtonStyle}" />
                </StackPanel>
            </StackPanel>

            <!-- Checklists -->
            <StackPanel Spacing="8">
                <Grid>
                    <TextBlock Text="Checklists" Style="{ThemeResource BodyStrongTextBlockStyle}"
                               VerticalAlignment="Center" />
                    <Button Content="Add checklist" HorizontalAlignment="Right" FontSize="12"
                            Click="AddChecklist_Click" />
                </Grid>
                <ItemsControl ItemsSource="{x:Bind Checklists}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ChecklistVm">
                            <StackPanel Spacing="6" Margin="0,4,0,10">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="{x:Bind Title, Mode=OneWay}" FontWeight="SemiBold"
                                             BorderThickness="0" Background="Transparent" Padding="4,2"
                                             Tag="{x:Bind}"
                                             LostFocus="ChecklistTitle_LostFocus" KeyDown="ChecklistTitle_KeyDown"
                                             ToolTipService.ToolTip="Click to rename this checklist" />
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                        <Button Content="Delete" FontSize="11"
                                                Click="DeleteChecklist_Click" Tag="{x:Bind}" />
                                    </StackPanel>
                                </Grid>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{x:Bind ProgressText, Mode=OneWay}"
                                               FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" MinWidth="32" />
                                    <ProgressBar Grid.Column="1" Value="{x:Bind Progress, Mode=OneWay}" Maximum="100" />
                                </Grid>
                                <ItemsControl ItemsSource="{x:Bind Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ChecklistItemVm">
                                            <Grid ColumnSpacing="4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox Grid.Column="0" Content="{x:Bind Text, Mode=OneWay}"
                                                          IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                                                          Checked="ChecklistItem_Toggled" Unchecked="ChecklistItem_Toggled"
                                                          Tag="{x:Bind}" />
                                                <Button Grid.Column="1" Background="Transparent" BorderThickness="0"
                                                        Padding="4" Click="DeleteChecklistItem_Click" Tag="{x:Bind}"
                                                        ToolTipService.ToolTip="Delete item">
                                                    <FontIcon Glyph="&#xE711;" FontSize="10" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Grid ColumnSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" PlaceholderText="Add an item…"
                                             Text="{x:Bind NewItemText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             KeyDown="AddChecklistItemBox_KeyDown" Tag="{x:Bind}" />
                                    <Button Grid.Column="1" Content="Add" Click="AddChecklistItem_Click" Tag="{x:Bind}" />
                                </Grid>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Attachments -->
            <StackPanel Spacing="8">
                <Grid>
                    <TextBlock Text="Attachments" Style="{ThemeResource BodyStrongTextBlockStyle}"
                               VerticalAlignment="Center" />
                    <Button Content="Attach file" HorizontalAlignment="Right" FontSize="12"
                            Click="AttachFile_Click" />
                </Grid>
                <ItemsControl ItemsSource="{x:Bind Attachments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:AttachmentVm">
                            <Grid ColumnSpacing="8" Padding="0,3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0" Width="24" Height="24">
                                    <Border CornerRadius="3" Background="{ThemeResource CardSurfaceBrush}"
                                            Visibility="{x:Bind IsImage}" Tapped="AttachmentThumbnail_Tapped" Tag="{x:Bind}"
                                            ToolTipService.ToolTip="Click to preview">
                                        <Image Source="{x:Bind Thumbnail}" Stretch="UniformToFill" />
                                    </Border>
                                    <FontIcon Glyph="&#xE723;" FontSize="13" Visibility="{x:Bind IsNotImage}" />
                                </Grid>
                                <TextBlock Grid.Column="1" Text="{x:Bind FileName}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Column="2" Text="{x:Bind TimeText}" FontSize="11" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <Button Grid.Column="3" Content="Preview" FontSize="11" Click="PreviewAttachment_Click"
                                        Tag="{x:Bind}" Visibility="{x:Bind IsPreviewable}" />
                                <Button Grid.Column="4" Content="Open" FontSize="11" Click="OpenAttachment_Click" Tag="{x:Bind}" />
                                <Button Grid.Column="5" Content="Remove" FontSize="11" Click="RemoveAttachment_Click" Tag="{x:Bind}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Comments -->
            <StackPanel Spacing="8">
                <TextBlock Text="Comments" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                <Grid ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="CommentBox" PlaceholderText="Write a comment…"
                             AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="80" Paste="CommentBox_Paste" />
                    <Button Grid.Column="1" Content="Comment" VerticalAlignment="Bottom" Click="AddComment_Click" />
                </Grid>
                <ItemsControl ItemsSource="{x:Bind Comments}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:CommentVm">
                            <Grid Padding="0,4" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Spacing="2">
                                    <TextBlock Text="{x:Bind TimeText}" FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <Border Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            CornerRadius="6" Padding="10,6" Tapped="CommentView_Tapped">
                                        <ContentControl Content="{x:Bind Text, Mode=OneWay, Converter={StaticResource Markdown}}"
                                                        HorizontalContentAlignment="Stretch" />
                                    </Border>
                                    <StackPanel Spacing="6" Visibility="Collapsed">
                                        <TextBox Text="{x:Bind Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 TextWrapping="Wrap" AcceptsReturn="True" Paste="CommentEditBox_Paste" />
                                        <Button Content="Save" Click="SaveComment_Click" Tag="{x:Bind}"
                                                HorizontalAlignment="Left" FontSize="12" />
                                    </StackPanel>
                                </StackPanel>
                                <Button Grid.Column="1" Content="Delete" FontSize="11" VerticalAlignment="Bottom"
                                        Click="DeleteComment_Click" Tag="{x:Bind}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Danger zone -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                <Button Click="ArchiveCard_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE7B8;" FontSize="13" />
                        <TextBlock Text="Archive card" />
                    </StackPanel>
                </Button>
                <Button Click="DeleteCard_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE74D;" FontSize="13" />
                        <TextBlock Text="Delete card" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
