<Page
    x:Class="Tossakan.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel MaxWidth="640" Padding="32,24" Spacing="12" HorizontalAlignment="Stretch">
            <TextBlock Text="Settings" Style="{ThemeResource TitleTextBlockStyle}" />

            <TextBlock Text="Homepage background photo" Style="{ThemeResource BodyStrongTextBlockStyle}" Margin="0,12,0,0" />
            <TextBlock Text="Shown behind your boards on the home screen." FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Border x:Name="NoPhotoSwatch" Width="72" Height="44" CornerRadius="4"
                        BorderThickness="2" BorderBrush="Transparent"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        Tapped="NoPhoto_Tapped">
                    <TextBlock Text="None" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <Border x:Name="DefaultPhotoSwatch" Width="72" Height="44" CornerRadius="4"
                        BorderThickness="2" BorderBrush="Transparent"
                        Tapped="DefaultPhoto_Tapped">
                    <Image x:Name="DefaultPhotoImage" Stretch="UniformToFill" />
                </Border>
                <Border x:Name="CustomPhotoSwatch" Width="72" Height="44" CornerRadius="4"
                        BorderThickness="2" BorderBrush="Transparent" Visibility="Collapsed"
                        Tapped="CustomPhoto_Tapped">
                    <Image x:Name="CustomPhotoImage" Stretch="UniformToFill" />
                </Border>
                <Button Content="Choose photo…" Click="BrowseImage_Click" VerticalAlignment="Center" />
            </StackPanel>

            <Button x:Name="SaveButton" Content="Save" Style="{ThemeResource AccentButtonStyle}"
                    Click="Save_Click" HorizontalAlignment="Left" Margin="0,16,0,0" />
            <TextBlock x:Name="SavedText" Text="Saved." FontSize="12" Visibility="Collapsed"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>
    </ScrollViewer>
</Page>
