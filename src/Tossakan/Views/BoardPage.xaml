<Page
    x:Class="Tossakan.Views.BoardPage"
    x:Name="page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Tossakan.ViewModels"
    xmlns:models="using:Tossakan.Models"
    xmlns:helpers="using:Tossakan.Helpers"
    SizeChanged="Page_SizeChanged"
    NavigationCacheMode="Disabled">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Board bar -->
        <Grid Grid.Row="0" Padding="16,10" ColumnSpacing="8" Background="#33000000">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Background="Transparent" BorderThickness="0"
                    Click="EditBoard_Click" ToolTipService.ToolTip="Rename board / change background">
                <TextBlock x:Name="BoardNameText" FontSize="18" FontWeight="Bold" Foreground="White" />
            </Button>
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                <Button x:Name="CopyBoardReferenceButton" Background="Transparent" BorderThickness="0" Foreground="White"
                        Click="CopyBoardReference_Click" ToolTipService.ToolTip="Copy reference">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                        <TextBlock Text="Copy Reference" />
                    </StackPanel>
                </Button>
                <Button x:Name="SettingsButton" Background="Transparent" BorderThickness="0" Foreground="White"
                        Click="EditBoard_Click" ToolTipService.ToolTip="Board settings: rename or change background">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE713;" FontSize="14" />
                        <TextBlock Text="Settings" />
                    </StackPanel>
                </Button>
                <Button x:Name="FilterButton" Background="Transparent" BorderThickness="0" Foreground="White">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE71C;" FontSize="14" />
                        <TextBlock x:Name="FilterButtonText" Text="Filter" />
                    </StackPanel>
                    <Button.Flyout>
                        <Flyout Placement="Bottom">
                            <StackPanel Width="280" Spacing="10">
                                <TextBox x:Name="FilterTextBox" Header="Keyword"
                                         PlaceholderText="Filter by title or description…"
                                         TextChanged="Filter_Changed" />
                                <TextBlock Text="Labels" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <ItemsControl x:Name="FilterLabelsList" ItemsSource="{x:Bind FilterLabels}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:LabelFilterVm">
                                            <CheckBox IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                                                      Checked="Filter_Changed" Unchecked="Filter_Changed"
                                                      MinWidth="0">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Border Width="24" Height="14" CornerRadius="3"
                                                            Background="{x:Bind Brush}" VerticalAlignment="Center" />
                                                    <TextBlock Text="{x:Bind DisplayName}" FontSize="12" />
                                                </StackPanel>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Due date" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                <RadioButtons x:Name="DueFilterRadios" SelectedIndex="0"
                                              SelectionChanged="Filter_Changed">
                                    <x:String>Any</x:String>
                                    <x:String>Overdue</x:String>
                                    <x:String>Due in the next week</x:String>
                                    <x:String>No due date</x:String>
                                </RadioButtons>
                                <Button Content="Clear filter" Click="ClearFilter_Click" />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button x:Name="ActivityButton" Background="Transparent" BorderThickness="0" Foreground="White"
                        ToolTipService.ToolTip="Board activity">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE81C;" FontSize="14" />
                        <TextBlock Text="Activity" />
                    </StackPanel>
                    <Button.Flyout>
                        <Flyout Placement="Bottom" Opening="ActivityFlyout_Opening">
                            <ListView x:Name="ActivityList" Width="360" MaxHeight="480" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:ActivityVm">
                                        <StackPanel Padding="0,6" Spacing="2">
                                            <TextBlock Text="{x:Bind Description}" TextWrapping="Wrap" FontSize="13" />
                                            <TextBlock Text="{x:Bind TimeText}" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <Button x:Name="ArchiveButton" Background="Transparent" BorderThickness="0" Foreground="White"
                        ToolTipService.ToolTip="Archived items">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE7B8;" FontSize="14" />
                        <TextBlock Text="Archive" />
                    </StackPanel>
                    <Button.Flyout>
                        <Flyout Placement="Bottom" Opening="ArchiveFlyout_Opening">
                            <ScrollViewer MaxHeight="480">
                                <StackPanel Width="360" Spacing="10">
                                    <TextBlock Text="Archived cards" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock x:Name="NoArchivedCardsText" Text="None" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <ItemsControl x:Name="ArchivedCardsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ArchivedItemVm">
                                                <Grid ColumnSpacing="8" Padding="0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Spacing="1">
                                                        <TextBlock Text="{x:Bind Title}" TextWrapping="Wrap" FontSize="13" />
                                                        <TextBlock Text="{x:Bind Subtitle}" FontSize="11"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="Restore" FontSize="11"
                                                            Click="RestoreArchivedCard_Click" Tag="{x:Bind}" />
                                                    <Button Grid.Column="2" Content="Delete" FontSize="11"
                                                            Click="DeleteArchivedCard_Click" Tag="{x:Bind}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <TextBlock Text="Archived lists" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock x:Name="NoArchivedListsText" Text="None" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <ItemsControl x:Name="ArchivedListsList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ArchivedItemVm">
                                                <Grid ColumnSpacing="8" Padding="0,4">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Text="{x:Bind Title}" VerticalAlignment="Center"
                                                               TextWrapping="Wrap" FontSize="13" />
                                                    <Button Grid.Column="1" Content="Restore" FontSize="11"
                                                            Click="RestoreArchivedList_Click" Tag="{x:Bind}" />
                                                    <Button Grid.Column="2" Content="Delete" FontSize="11"
                                                            Click="DeleteArchivedList_Click" Tag="{x:Bind}" />
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>
                        </Flyout>
                    </Button.Flyout>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Lists -->
        <ListView x:Name="ListsView" Grid.Row="1"
                  ItemsSource="{x:Bind Lists}"
                  SelectionMode="None"
                  CanDragItems="True" CanReorderItems="True" AllowDrop="True"
                  DragItemsCompleted="ListsView_DragItemsCompleted"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.HorizontalScrollMode="Enabled"
                  ScrollViewer.VerticalScrollBarVisibility="Disabled"
                  ScrollViewer.VerticalScrollMode="Disabled"
                  Padding="12,10,12,12">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="VerticalAlignment" Value="Top" />
                    <Setter Property="VerticalContentAlignment" Value="Top" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="Margin" Value="0,0,12,0" />
                    <Setter Property="MinWidth" Value="0" />
                    <Setter Property="MinHeight" Value="0" />
                </Style>
            </ListView.ItemContainerStyle>

            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:ListViewModel">
                    <Border Width="290" CornerRadius="10" VerticalAlignment="Top"
                            Background="{ThemeResource ListSurfaceBrush}" Padding="8">
                        <Grid RowSpacing="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- List header -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Text="{x:Bind Name, Mode=OneWay}"
                                         FontWeight="SemiBold" Margin="6,2,4,2" Padding="4,4"
                                         BorderThickness="0" Background="Transparent"
                                         Tag="{x:Bind}"
                                         LostFocus="ListName_LostFocus" KeyDown="ListName_KeyDown"
                                         ToolTipService.ToolTip="Click to rename this list" />
                                <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="6">
                                    <FontIcon Glyph="&#xE712;" FontSize="14" />
                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="Archive list" Click="ArchiveList_Click" Tag="{x:Bind}">
                                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE7B8;" /></MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutSeparator />
                                            <MenuFlyoutItem Text="Delete list" Click="DeleteList_Click" Tag="{x:Bind}">
                                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" /></MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                            </Grid>

                            <!-- Cards -->
                            <ListView Grid.Row="1"
                                      ItemsSource="{x:Bind Cards}"
                                      Tag="{x:Bind}"
                                      SelectionMode="None" IsItemClickEnabled="True"
                                      ItemClick="Cards_ItemClick"
                                      CanDragItems="True" CanReorderItems="True" AllowDrop="True"
                                      DragItemsStarting="Cards_DragItemsStarting"
                                      DragItemsCompleted="Cards_DragItemsCompleted"
                                      DragOver="Cards_DragOver"
                                      Drop="Cards_Drop"
                                      MinHeight="24"
                                      MaxHeight="{Binding CardsMaxHeight, ElementName=page}"
                                      ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,3" />
                                        <Setter Property="MinHeight" Value="0" />
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="vm:CardViewModel">
                                        <Grid CornerRadius="8"
                                              Background="{ThemeResource CardSurfaceBrush}"
                                              BorderThickness="1"
                                              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ContextFlyout>
                                                <MenuFlyout>
                                                    <MenuFlyoutItem Text="Open card" Click="OpenCardMenu_Click" Tag="{x:Bind}">
                                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8A7;" /></MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutItem Text="Archive card" Click="ArchiveCardMenu_Click" Tag="{x:Bind}">
                                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE7B8;" /></MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutSeparator />
                                                    <MenuFlyoutItem Text="Delete card" Click="DeleteCardMenu_Click" Tag="{x:Bind}">
                                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" /></MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                </MenuFlyout>
                                            </Grid.ContextFlyout>
                                            <Border Grid.Row="0" Height="8" CornerRadius="8,8,0,0"
                                                    Background="{x:Bind CoverBrush}"
                                                    Visibility="{x:Bind HasCover}" />
                                            <StackPanel Grid.Row="1" Padding="10,8" Spacing="6">
                                                <ItemsControl ItemsSource="{x:Bind Labels}" Visibility="{x:Bind HasLabels}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" Spacing="4" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="models:Label">
                                                            <Border CornerRadius="4" Height="16" MinWidth="36" Padding="6,0"
                                                                    Background="{x:Bind Color, Converter={StaticResource ColorToBrush}}">
                                                                <TextBlock Text="{x:Bind Name}" FontSize="10" Foreground="White"
                                                                           VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <TextBlock Text="{x:Bind ReferenceCode}" FontSize="10"
                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                <TextBlock Text="{x:Bind Title}" TextWrapping="Wrap" FontSize="14" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Border CornerRadius="4" Padding="6,2"
                                                            Background="{x:Bind DueBrush}" Visibility="{x:Bind HasDue}">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <FontIcon Glyph="&#xE823;" FontSize="11" Foreground="White" />
                                                            <TextBlock Text="{x:Bind DueText}" FontSize="11" Foreground="White" />
                                                        </StackPanel>
                                                    </Border>
                                                    <FontIcon Glyph="&#xE7C3;" FontSize="12" VerticalAlignment="Center"
                                                              Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                              Visibility="{x:Bind HasDescription}" />
                                                    <Border CornerRadius="4" Padding="6,2"
                                                            Background="{x:Bind ChecklistBrush}" Visibility="{x:Bind HasChecklist}">
                                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                                            <FontIcon Glyph="&#xE73A;" FontSize="11" Foreground="White" />
                                                            <TextBlock Text="{x:Bind ChecklistText}" FontSize="11" Foreground="White" />
                                                        </StackPanel>
                                                    </Border>
                                                    <StackPanel Orientation="Horizontal" Spacing="4"
                                                                Visibility="{x:Bind HasComments}">
                                                        <FontIcon Glyph="&#xE90A;" FontSize="12" VerticalAlignment="Center"
                                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                        <TextBlock Text="{x:Bind CommentText}" FontSize="11" VerticalAlignment="Center"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" Spacing="4"
                                                                Visibility="{x:Bind HasAttachments}">
                                                        <FontIcon Glyph="&#xE723;" FontSize="12" VerticalAlignment="Center"
                                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                        <TextBlock Text="{x:Bind AttachmentText}" FontSize="11" VerticalAlignment="Center"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!-- Add card -->
                            <Grid Grid.Row="2">
                                <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                        Background="Transparent" BorderThickness="0"
                                        Click="ShowAddCard_Click" Tag="{x:Bind}"
                                        Visibility="{x:Bind helpers:Ui.VisibleIfNot(IsAddingCard), Mode=OneWay}">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE710;" FontSize="12" />
                                        <TextBlock Text="Add a card" />
                                    </StackPanel>
                                </Button>
                                <StackPanel Spacing="6"
                                            Visibility="{x:Bind helpers:Ui.VisibleIf(IsAddingCard), Mode=OneWay}">
                                    <TextBox Text="{x:Bind NewCardText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             PlaceholderText="Enter a title for this card…"
                                             TextWrapping="Wrap" AcceptsReturn="False"
                                             KeyDown="AddCardBox_KeyDown" Tag="{x:Bind}" />
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Button Content="Add card" Style="{ThemeResource AccentButtonStyle}"
                                                Click="ConfirmAddCard_Click" Tag="{x:Bind}" />
                                        <Button Content="Cancel" Click="CancelAddCard_Click" Tag="{x:Bind}" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>

            <ListView.Footer>
                <Grid VerticalAlignment="Top" Width="290" Margin="0,0,0,0">
                    <Button x:Name="AddListButton" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                            Background="#4DFFFFFF" Click="ShowAddList_Click">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE710;" FontSize="12" />
                            <TextBlock Text="Add another list" />
                        </StackPanel>
                    </Button>
                    <StackPanel x:Name="AddListPanel" Spacing="6" Visibility="Collapsed"
                                Background="{ThemeResource ListSurfaceBrush}" CornerRadius="10" Padding="8">
                        <TextBox x:Name="AddListBox" PlaceholderText="Enter list name…"
                                 KeyDown="AddListBox_KeyDown" />
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Content="Add list" Style="{ThemeResource AccentButtonStyle}"
                                    Click="ConfirmAddList_Click" />
                            <Button Content="Cancel" Click="CancelAddList_Click" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </ListView.Footer>
        </ListView>
    </Grid>
</Page>
