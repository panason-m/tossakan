<ContentDialog
    x:Class="Tossakan.Views.BoardEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="Primary">
    <StackPanel Spacing="12" MinWidth="340">
        <TextBox x:Name="NameBox" Header="Board name" MaxLength="120" />
        <TextBlock Text="Color" Style="{ThemeResource BodyStrongTextBlockStyle}" />
        <GridView x:Name="PaletteView" SelectionMode="Single" IsItemClickEnabled="False">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Border Width="56" Height="36" CornerRadius="4"
                            Background="{Binding Converter={StaticResource ColorToBrush}}" />
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <TextBlock Text="Background photo" Style="{ThemeResource BodyStrongTextBlockStyle}" />
        <TextBlock Text="A photo covers the color above." FontSize="11"
                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        <StackPanel Orientation="Horizontal" Spacing="8">
            <Border x:Name="NoPhotoSwatch" Width="72" Height="44" CornerRadius="4"
                    BorderThickness="2" BorderBrush="Transparent"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    Tapped="NoPhoto_Tapped">
                <TextBlock Text="None" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <Border x:Name="DefaultPhotoSwatch" Width="72" Height="44" CornerRadius="4"
                    BorderThickness="2" BorderBrush="Transparent"
                    Tapped="DefaultPhoto_Tapped">
                <Image x:Name="DefaultPhotoImage" Stretch="UniformToFill" />
            </Border>
            <Border x:Name="CustomPhotoSwatch" Width="72" Height="44" CornerRadius="4"
                    BorderThickness="2" BorderBrush="Transparent" Visibility="Collapsed"
                    Tapped="CustomPhoto_Tapped">
                <Image x:Name="CustomPhotoImage" Stretch="UniformToFill" />
            </Border>
            <Button Content="Choose photo…" Click="BrowseImage_Click" VerticalAlignment="Center" />
        </StackPanel>
    </StackPanel>
</ContentDialog>
