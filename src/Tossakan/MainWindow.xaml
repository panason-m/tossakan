<Window
    x:Class="Tossakan.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:Tossakan.ViewModels">
    <NavigationView x:Name="NavView"
                    PaneDisplayMode="Left" OpenPaneLength="200"
                    IsSettingsVisible="False" IsBackButtonVisible="Collapsed"
                    IsPaneToggleButtonVisible="False"
                    ItemInvoked="NavView_ItemInvoked">
        <NavigationView.MenuItems>
            <NavigationViewItem x:Name="HomeItem" Content="Home" Tag="home">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE80F;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Settings" Tag="settings">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE713;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="User Manual" Tag="manual">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE897;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Grid x:Name="RootGrid" Loaded="RootGrid_Loaded">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="QuickViewColumn" Width="260" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Padding="8,6" ColumnSpacing="8"
                  Background="{ThemeResource LayerFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                  BorderThickness="0,0,0,1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button x:Name="BackButton" Grid.Column="0" IsEnabled="False"
                        Click="BackButton_Click" ToolTipService.ToolTip="Back">
                    <FontIcon Glyph="&#xE72B;" FontSize="14" />
                </Button>
                <TextBlock Grid.Column="1" Text="Tossakan"
                           VerticalAlignment="Center" FontWeight="SemiBold" Margin="8,0,0,0" />
                <AutoSuggestBox x:Name="SearchBox" Grid.Column="3" Width="340"
                                PlaceholderText="Search cards…" QueryIcon="Find"
                                VerticalAlignment="Center"
                                TextChanged="SearchBox_TextChanged"
                                SuggestionChosen="SearchBox_SuggestionChosen" />
            </Grid>

            <Frame x:Name="RootFrame" Grid.Row="1" Grid.Column="0" Navigated="RootFrame_Navigated" />

            <!-- Quick View: expanded panel -->
            <Border x:Name="QuickViewPanel" Grid.Row="1" Grid.Column="1"
                    BorderThickness="1,0,0,0"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Padding="12,8" ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Quick View"
                                   Style="{ThemeResource BodyStrongTextBlockStyle}"
                                   VerticalAlignment="Center" />
                        <Button x:Name="NoDueDateFilterButton" Grid.Column="1" Background="Transparent" BorderThickness="0"
                                Padding="4" VerticalAlignment="Center" Visibility="Collapsed"
                                Click="NoDueDateFilterButton_Click"
                                ToolTipService.ToolTip="Show only cards without a due date">
                            <StackPanel Orientation="Horizontal" Spacing="3">
                                <FontIcon x:Name="NoDueDateBellIcon" Glyph="&#xEA8F;" FontSize="14"
                                          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock x:Name="NoDueDateCountText" Text="0" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2" Background="Transparent" BorderThickness="0"
                                Click="QuickViewRefreshButton_Click" ToolTipService.ToolTip="Refresh">
                            <FontIcon Glyph="&#xE72C;" FontSize="14" />
                        </Button>
                        <Button Grid.Column="3" Background="Transparent" BorderThickness="0"
                                Click="QuickViewToggleButton_Click" ToolTipService.ToolTip="Collapse">
                            <FontIcon Glyph="&#xE76C;" FontSize="14" />
                        </Button>
                    </Grid>

                    <ListView x:Name="QuickViewList" Grid.Row="1"
                              SelectionMode="None" IsItemClickEnabled="True"
                              ItemClick="QuickViewList_ItemClick">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="vm:QuickViewCardVm">
                                <Grid Padding="8,6" ColumnSpacing="4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Spacing="4">
                                        <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" TextWrapping="Wrap" />
                                        <Border Background="{x:Bind DueBrush}" CornerRadius="4"
                                                Padding="6,1" HorizontalAlignment="Left">
                                            <TextBlock Text="{x:Bind DueText}" FontSize="11" Foreground="White" />
                                        </Border>
                                        <TextBlock Text="{x:Bind LocationText}" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button Grid.Column="1" VerticalAlignment="Top" Background="Transparent"
                                            BorderThickness="0" Padding="4" Tag="{x:Bind}"
                                            Click="MoveListButton_Click" ToolTipService.ToolTip="Move to list…">
                                        <FontIcon Glyph="&#xE712;" FontSize="12" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Quick View: collapsed rail -->
            <Border x:Name="QuickViewCollapsedStrip" Grid.Row="1" Grid.Column="1"
                    Visibility="Collapsed"
                    BorderThickness="1,0,0,0"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                    Background="{ThemeResource LayerFillColorDefaultBrush}">
                <Button HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8,0,0"
                        Background="Transparent" BorderThickness="0"
                        Click="QuickViewToggleButton_Click" ToolTipService.ToolTip="Expand Quick View">
                    <FontIcon Glyph="&#xE76B;" FontSize="14" />
                </Button>
            </Border>
        </Grid>
    </NavigationView>
</Window>
